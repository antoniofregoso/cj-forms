{
  "name": "@customerjourney/cj-forms",
  "version": "1.0.0",
  "description": "Macro-components for creating forms",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.min.js",
  "exports": {
    ".": {
      "import": "./dist/index.min.js"
    }
  },
  "scripts": {
    "prod": "esbuild src/index.js --bundle --minify --format=esm --jsx=automatic --jsx-import-source=preact --external:@customerjourney/cj-core --outfile=dist/index.min.js",
    "build": "esbuild src/index.js --bundle --format=esm --jsx=automatic --jsx-import-source=preact --external:@customerjourney/cj-core --outfile=dist/index.js",
    "pretest": "npm run build",
    "test": "node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antoniofregoso/cj-forms.git"
  },
  "author": "Antonio Fregoso <antoniofregoso@protonmail.com>",
  "license": "GPL-3.0-or-later",
  "peerDependencies": {
    "@customerjourney/cj-core": "^1.13.0"
  },
  "devDependencies": {
    "@customerjourney/cj-core": "^1.13.0",
    "esbuild": "^0.25.6",
    "jsdom": "^29.1.1"
  },
  "dependencies": {
    "libphonenumber-js": "^1.11.4",
    "preact": "^10.29.4",
    "remarkable": "^2.0.1",
    "vanilla-calendar-pro": "^3.0.4"
  },
  "bugs": {
    "url": "https://github.com/antoniofregoso/cj-forms/issues"
  },
  "homepage": "https://antoniofregoso.github.io/customerjourney/documentation/forms/",
  "keywords": [
    "vanilla-javascript",
    "components",
    "funnels",
    "touchpoints"
  ]
}
